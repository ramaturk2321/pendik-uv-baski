---
import { socialLinks, contact, company, hizmetler } from '../lib/site-data';

const navLinks = [
  { href: '/portfolyo', label: 'Portfolyo' },
  { href: '/hakkimizda', label: 'Hakkımızda' },
  { href: '/blog', label: 'Blog' },
  { href: '/iletisim', label: 'İletişim' },
];

const currentPath = Astro.url.pathname;
---

<header id="header" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <!-- ===== ÜST BİLGİ BARI ===== -->
  <div class="bg-koyu-800 text-koyu-300 hidden lg:block">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-10">
        <!-- Sol: Telefon + E-posta -->
        <div class="flex items-center gap-6 text-sm">
          <a href={contact.phoneHref} class="flex items-center gap-2 hover:text-white transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {contact.phone}
          </a>
          <a href={contact.mobileHref} class="flex items-center gap-2 hover:text-white transition-colors font-semibold text-white">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            {contact.mobile}
          </a>
          <a href={contact.emailHref} class="flex items-center gap-2 hover:text-white transition-colors">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            {contact.email}
          </a>
        </div>

        <!-- Sağ: Sosyal Medya -->
        <div class="flex items-center gap-3">
          {socialLinks.map(s => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="w-7 h-7 bg-koyu-700 hover:bg-eymen-500 rounded-full flex items-center justify-center transition-colors" aria-label={s.name}>
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon}/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- ===== ANA MENÜ BARI ===== -->
  <div class="bg-white border-b border-koyu-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-20 md:h-24">
        <!-- Logo -->
        <a href="/" class="flex-shrink-0">
          <img src={company.logoPath} alt={company.name} class="h-20 md:h-24 w-auto" />
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden lg:flex items-center gap-1">
          <!-- Hizmetlerimiz Dropdown -->
          <div class="relative group" id="hizmet-dropdown">
            <button class="flex items-center gap-1.5 px-5 py-2.5 text-[15px] font-semibold text-koyu-700 hover:text-eymen-600 transition-colors">
              Hizmetlerimiz
              <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <!-- Mega Menu -->
            <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 absolute top-full left-0 pt-2 z-50">
              <div class="bg-white rounded-2xl shadow-2xl border border-koyu-100 p-6 w-[600px]">
                <div class="grid grid-cols-2 gap-3">
                  {hizmetler.map(h => (
                    <a href={`/hizmetlerimiz/${h.id}`} class="flex items-center gap-3 p-3 rounded-xl hover:bg-eymen-50 transition-colors group/item">
                      <span class="text-xl">{h.icon}</span>
                      <div>
                        <span class="text-sm font-medium text-koyu-700 group-hover/item:text-eymen-600 transition-colors block">{h.title}</span>
                        <span class="text-xs text-koyu-400">{h.shortDesc}</span>
                      </div>
                    </a>
                  ))}
                </div>
                <div class="mt-4 pt-4 border-t border-koyu-100">
                  <a href="/hizmetlerimiz" class="text-sm text-eymen-600 font-semibold hover:text-eymen-700 transition-colors">
                    Tüm Hizmetleri Görüntüle →
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Normal Links -->
          {navLinks.map(link => (
            <a
              href={link.href}
              class:list={[
                'px-5 py-2.5 text-[15px] font-semibold transition-colors',
                currentPath === link.href
                  ? 'text-eymen-600'
                  : 'text-koyu-700 hover:text-eymen-600'
              ]}
            >
              {link.label}
            </a>
          ))}
        </nav>

        <!-- Sağ: CTA + Mobil -->
        <div class="flex items-center gap-3">
          <!-- Teklif CTA Desktop -->
          <a
            href="/teklif-al"
            class="hidden lg:inline-flex items-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-6 py-3 rounded-lg text-sm font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/20"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Online Teklif Al
          </a>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="lg:hidden p-2 rounded-lg text-koyu-600 hover:bg-koyu-50" aria-label="Menü">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="lg:hidden hidden border-t border-koyu-100 bg-white max-h-[80vh] overflow-y-auto">
      <div class="px-4 py-4 space-y-1">
        <!-- Mobil Telefon + E-posta -->
        <div class="flex flex-col gap-2 pb-3 mb-3 border-b border-koyu-100">
          <a href={contact.phoneHref} class="flex items-center gap-2 text-sm text-koyu-600">
            <svg class="w-4 h-4 text-eymen-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            {contact.phone}
          </a>
          <a href={contact.mobileHref} class="flex items-center gap-2 text-sm font-semibold text-koyu-800">
            <svg class="w-4 h-4 text-eymen-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
            {contact.mobile}
          </a>
        </div>

        <!-- Hizmetler Accordion -->
        <div>
          <button class="mobile-accordion-btn w-full flex items-center justify-between px-4 py-3 rounded-lg text-sm font-semibold text-koyu-700 hover:bg-koyu-50">
            Hizmetlerimiz
            <svg class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="mobile-accordion-content hidden pl-4 space-y-1">
            {hizmetler.map(h => (
              <a href={`/hizmetlerimiz/${h.id}`} class="flex items-center gap-2 px-4 py-2 text-sm text-koyu-500 hover:text-eymen-600 hover:bg-koyu-50 rounded-lg">
                <span>{h.icon}</span> {h.title}
              </a>
            ))}
          </div>
        </div>

        {navLinks.map(link => (
          <a href={link.href} class="block px-4 py-3 rounded-lg text-sm font-semibold text-koyu-700 hover:bg-koyu-50">
            {link.label}
          </a>
        ))}

        <a href="/teklif-al" class="block w-full text-center bg-eymen-500 hover:bg-eymen-600 text-white px-4 py-3 rounded-lg text-sm font-bold mt-3">
          Online Teklif Al
        </a>

        <!-- Mobil Sosyal Medya -->
        <div class="flex items-center justify-center gap-4 pt-3 border-t border-koyu-100 mt-3">
          {socialLinks.map(s => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="w-9 h-9 bg-koyu-100 hover:bg-eymen-500 hover:text-white rounded-full flex items-center justify-center transition-colors text-koyu-500" aria-label={s.name}>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d={s.icon}/></svg>
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

  // Mobile accordion
  document.querySelectorAll('.mobile-accordion-btn').forEach(b => {
    b.addEventListener('click', () => {
      const content = b.nextElementSibling;
      const icon = b.querySelector('svg');
      content?.classList.toggle('hidden');
      icon?.classList.toggle('rotate-180');
    });
  });
</script>
