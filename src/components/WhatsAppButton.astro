---
import { getWhatsAppUrl, whatsappIcon } from '../lib/site-data';
---

<!-- Floating WhatsApp Button — sağ alt köşe -->
<a
  href={getWhatsAppUrl()}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-50 bg-green-500 hover:bg-green-600 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all hover:scale-110"
  aria-label="WhatsApp ile iletişime geçin"
>
  <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
    <path d={whatsappIcon}/>
  </svg>
</a>
