---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter(p => p.data.published);
const sortedPosts = posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Blog" description="UV baskı hakkında bilgilendirici yazılar, malzeme rehberleri ve sektör haberleri.">

  <!-- Hero -->
  <section class="bg-koyu-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Blog</h1>
      <p class="text-koyu-300 text-lg max-w-2xl mx-auto">UV baskı dünyasından bilgiler, ipuçları ve rehberler.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map(post => (
            <a href={`/blog/${post.id}`} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-koyu-100">
              <div class="aspect-[16/9] overflow-hidden bg-koyu-100">
                <img src={post.data.image} alt={post.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
              </div>
              <div class="p-5">
                <div class="flex items-center gap-3 mb-3">
                  <span class="text-xs font-semibold text-eymen-600 bg-eymen-50 px-3 py-1 rounded-full">{post.data.category}</span>
                  <span class="text-xs text-koyu-400">{post.data.date}</span>
                </div>
                <h3 class="text-lg font-bold text-koyu-800 group-hover:text-eymen-600 transition-colors">{post.data.title}</h3>
                <p class="text-sm text-koyu-500 mt-2">{post.data.excerpt}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-20">
          <span class="text-6xl mb-4 block">📝</span>
          <h2 class="text-2xl font-bold text-koyu-800 mb-3">Blog Yazıları Yakında</h2>
          <p class="text-koyu-500 max-w-md mx-auto">UV baskı hakkında bilgilendirici yazılarımızı yakında burada paylaşacağız.</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
