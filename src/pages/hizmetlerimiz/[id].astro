---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getWhatsAppUrl } from '../../lib/site-data';

export async function getStaticPaths() {
  const hizmetler = await getCollection('hizmetler');
  return hizmetler.map(h => ({
    params: { id: h.id },
    props: { hizmet: h },
  }));
}

const { hizmet } = Astro.props;
const data = hizmet.data;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: 'https://www.pendikuvbaski.com/' },
    { '@type': 'ListItem', position: 2, name: 'Hizmetlerimiz', item: 'https://www.pendikuvbaski.com/hizmetlerimiz/' },
    { '@type': 'ListItem', position: 3, name: data.title },
  ],
};

const faqSchema = data.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: data.faq.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;
---

<BaseLayout title={data.title} description={data.description}>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <!-- Breadcrumb -->
  <nav class="bg-koyu-50 border-b border-koyu-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-koyu-500">
        <li><a href="/" class="hover:text-eymen-600 transition-colors">Ana Sayfa</a></li>
        <li><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li><a href="/hizmetlerimiz" class="hover:text-eymen-600 transition-colors">Hizmetlerimiz</a></li>
        <li><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-koyu-800 font-medium">{data.title}</li>
      </ol>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-koyu-800 to-koyu-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <span class="text-5xl mb-4 block">{data.icon}</span>
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4">{data.title}</h1>
        <p class="text-koyu-300 text-lg leading-relaxed">{data.heroDesc}</p>
        <a href="/teklif-al" class="inline-flex items-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-8 py-4 rounded-xl text-lg font-bold transition-all mt-8">
          Teklif Al
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-koyu-800 mb-10 text-center">Neden {data.title}?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        {data.features.map(f => (
          <div class="bg-white rounded-2xl p-6 border border-koyu-100 shadow-sm">
            <span class="text-3xl mb-3 block">{f.icon}</span>
            <h3 class="text-lg font-bold text-koyu-800 mb-2">{f.title}</h3>
            <p class="text-sm text-koyu-500">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Süreç -->
  <section class="py-20 bg-koyu-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-koyu-800 mb-10 text-center">Nasıl Çalışıyoruz?</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {data.process.map(p => (
          <div class="relative">
            <span class="text-6xl font-extrabold text-eymen-100 absolute -top-2 left-0">{p.step}</span>
            <div class="pt-12">
              <h3 class="text-lg font-bold text-koyu-800 mb-2">{p.title}</h3>
              <p class="text-sm text-koyu-500">{p.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Kullanım Alanları -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-koyu-800 mb-10 text-center">Kullanım Alanları</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4 max-w-3xl mx-auto">
        {data.useCases.map(uc => (
          <div class="flex items-center gap-2 bg-eymen-50 rounded-xl px-4 py-3">
            <svg class="w-5 h-5 text-eymen-500 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm font-medium text-koyu-700">{uc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SSS -->
  {data.faq.length > 0 && (
    <section class="py-20 bg-koyu-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-extrabold text-koyu-800 mb-10 text-center">Sıkça Sorulan Sorular</h2>
        <div class="space-y-4">
          {data.faq.map(f => (
            <details class="bg-white rounded-xl border border-koyu-100 overflow-hidden group">
              <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-koyu-700 hover:text-eymen-600 transition-colors">
                {f.q}
                <svg class="w-5 h-5 text-koyu-400 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <div class="px-5 pb-5 text-koyu-500 text-sm leading-relaxed border-t border-koyu-50">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-eymen-500 py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-extrabold text-white mb-4">{data.title} İçin Teklif Alın</h2>
      <p class="text-eymen-100 text-lg mb-8">Boyut ve adet bilgilerinizi gönderin, hemen fiyat teklifi sunalım.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/teklif-al" class="inline-flex items-center justify-center bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-4 rounded-xl text-lg font-bold transition-all">
          Online Teklif Formu
        </a>
        <a href={getWhatsAppUrl(`Merhaba, ${data.title} hakkında teklif almak istiyorum.`)} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-eymen-600 px-8 py-4 rounded-xl text-lg font-bold transition-all">
          WhatsApp ile Sor
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
