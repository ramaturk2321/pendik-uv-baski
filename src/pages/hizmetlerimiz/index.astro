---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { hizmetler } from '../../lib/site-data';
---

<BaseLayout title="Hizmetlerimiz" description="Pendik UV Baskı Merkezi hizmetleri — Cam, pleksi, ahşap, metal, seramik, kompozit, foreks ve deri UV baskı.">

  <!-- Hero -->
  <section class="bg-koyu-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">UV Baskı Hizmetlerimiz</h1>
      <p class="text-koyu-300 text-lg max-w-2xl mx-auto">8 farklı malzeme türüne profesyonel UV baskı çözümleri sunuyoruz.</p>
    </div>
  </section>

  <!-- Hizmet Grid -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {hizmetler.map(h => (
          <a href={`/hizmetlerimiz/${h.id}`} class="group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 border border-koyu-100 hover:border-eymen-200">
            <div class="bg-koyu-50 p-8 text-center">
              <span class="text-6xl">{h.icon}</span>
            </div>
            <div class="p-6">
              <h2 class="text-xl font-bold text-koyu-800 group-hover:text-eymen-600 transition-colors mb-2">{h.title}</h2>
              <p class="text-koyu-500 text-sm leading-relaxed mb-4">{h.shortDesc}</p>
              <span class="inline-flex items-center gap-1 text-eymen-600 text-sm font-semibold group-hover:gap-2 transition-all">
                Detaylı Bilgi
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
