---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact, company } from '../lib/site-data';
---

<BaseLayout title="İletişim" description="Pendik UV Baskı Merkezi iletişim bilgileri — Adres, telefon, e-posta ve harita.">

  <!-- Hero -->
  <section class="bg-koyu-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">İletişim</h1>
      <p class="text-koyu-300 text-lg">Bize ulaşmak için aşağıdaki kanalları kullanabilirsiniz.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- İletişim Bilgileri -->
        <div>
          <h2 class="text-2xl font-bold text-koyu-800 mb-8">İletişim Bilgileri</h2>

          <div class="space-y-6">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-eymen-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-koyu-800 mb-1">Adres</h3>
                <p class="text-koyu-500">{contact.address}</p>
                <a href={contact.mapsUrl} target="_blank" rel="noopener noreferrer" class="text-eymen-600 text-sm font-semibold hover:underline mt-1 inline-block">Haritada Göster →</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-eymen-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-koyu-800 mb-1">Telefon</h3>
                <p><a href={contact.phoneHref} class="text-koyu-500 hover:text-eymen-600 transition-colors">{contact.phone}</a></p>
                <p><a href={contact.mobileHref} class="text-koyu-800 font-semibold hover:text-eymen-600 transition-colors">{contact.mobile}</a></p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-eymen-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-koyu-800 mb-1">E-posta</h3>
                <a href={contact.emailHref} class="text-koyu-500 hover:text-eymen-600 transition-colors">{contact.email}</a>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-koyu-800 mb-1">WhatsApp</h3>
                <a href={contact.whatsappUrl} target="_blank" rel="noopener noreferrer" class="text-green-600 font-semibold hover:underline">{contact.mobile}</a>
              </div>
            </div>
          </div>

          <!-- Çalışma Saatleri -->
          <div class="mt-10 bg-koyu-50 rounded-2xl p-6">
            <h3 class="font-bold text-koyu-800 mb-4">Çalışma Saatleri</h3>
            <div class="space-y-2 text-sm">
              <div class="flex justify-between"><span class="text-koyu-600">Pazartesi - Cuma</span><span class="font-semibold text-koyu-800">09:00 - 18:30</span></div>
              <div class="flex justify-between"><span class="text-koyu-600">Cumartesi</span><span class="font-semibold text-koyu-800">09:00 - 14:00</span></div>
              <div class="flex justify-between"><span class="text-koyu-600">Pazar</span><span class="font-semibold text-red-500">Kapalı</span></div>
            </div>
          </div>
        </div>

        <!-- İletişim Formu -->
        <div>
          <h2 class="text-2xl font-bold text-koyu-800 mb-8">Bize Yazın</h2>
          <form class="space-y-6">
            <div>
              <label for="contact-name" class="block text-sm font-semibold text-koyu-700 mb-2">Ad Soyad *</label>
              <input type="text" id="contact-name" name="name" required class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="contact-phone" class="block text-sm font-semibold text-koyu-700 mb-2">Telefon *</label>
                <input type="tel" id="contact-phone" name="phone" required class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" />
              </div>
              <div>
                <label for="contact-email" class="block text-sm font-semibold text-koyu-700 mb-2">E-posta</label>
                <input type="email" id="contact-email" name="email" class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" />
              </div>
            </div>
            <div>
              <label for="contact-message" class="block text-sm font-semibold text-koyu-700 mb-2">Mesajınız *</label>
              <textarea id="contact-message" name="message" rows="5" required class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors resize-none"></textarea>
            </div>
            <button type="submit" class="w-full bg-eymen-500 hover:bg-eymen-600 text-white py-4 rounded-xl text-lg font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/20">
              Mesajı Gönder
            </button>
          </form>
        </div>
      </div>

      <!-- Harita -->
      <div class="mt-16 rounded-2xl overflow-hidden border border-koyu-100 shadow-sm">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3017.8!2d29.25!3d40.88!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDDCsDUyJzQ4LjAiTiAyOcKwMTUnMDAuMCJF!5e0!3m2!1str!2str!4v1"
          width="100%"
          height="400"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Pendik UV Baskı Merkezi Konum"
        ></iframe>
      </div>
    </div>
  </section>

</BaseLayout>
