---
import BaseLayout from '../layouts/BaseLayout.astro';
import { company, contact, hizmetler, getWhatsAppUrl } from '../lib/site-data';
---

<BaseLayout title="Ana Sayfa" description="Pendik UV Baskı Merkezi — Cam, pleksi, ahşap, metal ve daha birçok yüzeye profesyonel UV baskı hizmeti. Pendik İstanbul.">

  <!-- LocalBusiness + Organization Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": ["LocalBusiness", "Organization"],
    "name": "Pendik UV Baskı Merkezi",
    "alternateName": "Eymen Reklam",
    "legalName": "Eymen Reklam Matbaa Tabela İnşaat Gıda San. Tic. Ltd. Şti.",
    "description": "Cam, pleksi, ahşap, metal, seramik ve daha birçok yüzeye profesyonel UV baskı, tabela imalatı ve dijital baskı hizmeti. 2000 yılından bu yana Pendik İstanbul'da hizmet vermektedir.",
    "url": "https://www.pendikuvbaski.com",
    "logo": "https://www.pendikuvbaski.com/images/uv-logo.png",
    "image": "https://www.pendikuvbaski.com/images/hero-bg.jpg",
    "telephone": "+902163790708",
    "email": "info@eymenreklam.com",
    "foundingDate": "2000",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Esenler Mah. Çevre Sk. No: 7",
      "addressLocality": "Pendik",
      "addressRegion": "İstanbul",
      "postalCode": "34890",
      "addressCountry": "TR"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 40.8803,
      "longitude": 29.2336
    },
    "openingHoursSpecification": [
      {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
        "opens": "09:00",
        "closes": "18:30"
      }
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+905356647752",
      "contactType": "customer service",
      "availableLanguage": "Turkish"
    },
    "sameAs": [
      "https://www.instagram.com/eymenreklamltd/",
      "https://www.youtube.com/@eymenreklamltd",
      "https://www.linkedin.com/company/eymenreklamltd/",
      "https://www.facebook.com/eymenreklamltd/",
      "https://www.eymenreklam.com.tr",
      "https://www.eymenreklam.com"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "UV Baskı ve Reklam Hizmetleri",
      "itemListElement": [
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "UV Baskı"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Tabela İmalatı"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Afiş Baskı"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Bez / Branda Baskı"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Dijital Baskı"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Folyo & Araç Giydirme"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Grafik Tasarım"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "İş Güvenliği Levhaları"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Mağaza Reklam Uygulamaları"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Sunum & Stand"}}
      ]
    },
    "areaServed": {
      "@type": "City",
      "name": "İstanbul"
    },
    "priceRange": "₺₺"
  })} />

  <!-- ===== HERO ===== -->
  <section class="relative text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/hero-bg.jpg" alt="UV baskı makinesi çalışırken" class="w-full h-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-r from-koyu-900/90 via-koyu-900/75 to-koyu-900/50"></div>
    </div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-36 relative">
      <div class="max-w-3xl">
        <span class="inline-block bg-eymen-500/20 text-eymen-400 text-sm font-semibold px-4 py-1.5 rounded-full mb-6 fade-up">
          {company.experience} Yıllık Tecrübe
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold leading-tight mb-6 fade-up fade-up-delay-1">
          Her Yüzeye <span class="text-eymen-400">UV Baskı</span> Çözümleri
        </h1>
        <p class="text-lg md:text-xl text-koyu-300 leading-relaxed mb-8 fade-up fade-up-delay-2">
          Cam, pleksi, ahşap, metal, seramik ve daha birçok malzemeye yüksek çözünürlüklü, dayanıklı UV baskı. Pendik İstanbul'da üretim tesisimizde hizmetinizdeyiz.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 fade-up fade-up-delay-3">
          <a href="/teklif-al" class="inline-flex items-center justify-center gap-2 bg-eymen-500 hover:bg-eymen-600 text-white px-8 py-4 rounded-xl text-lg font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/30">
            Online Teklif Al
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href={getWhatsAppUrl()} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 border-2 border-green-500 text-green-400 hover:bg-green-500 hover:text-white px-8 py-4 rounded-xl text-lg font-bold transition-all">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
            WhatsApp İletişim
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== HİZMETLER ===== -->
  <section class="py-20 bg-koyu-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-800 mb-4">UV Baskı Hizmetlerimiz</h2>
        <p class="text-koyu-500 text-lg max-w-2xl mx-auto">Her malzemeye özel UV baskı çözümleri ile projelerinize hayat veriyoruz.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {hizmetler.map(h => (
          <a href={`/hizmetlerimiz/${h.id}`} class="group bg-white rounded-2xl p-6 shadow-sm hover:shadow-xl transition-all duration-300 border border-koyu-100 hover:border-eymen-200">
            <span class="text-4xl block mb-4">{h.icon}</span>
            <h3 class="text-lg font-bold text-koyu-800 group-hover:text-eymen-600 transition-colors mb-2">{h.title}</h3>
            <p class="text-sm text-koyu-500 leading-relaxed">{h.shortDesc}</p>
            <span class="inline-flex items-center gap-1 text-eymen-600 text-sm font-semibold mt-4 group-hover:gap-2 transition-all">
              Detaylı Bilgi
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== NEDEN BİZ ===== -->
  <section class="py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-4xl font-extrabold text-koyu-800 mb-4">Neden Bizi Tercih Etmelisiniz?</h2>
        <p class="text-koyu-500 text-lg max-w-2xl mx-auto">Kaliteli üretim, hızlı teslimat ve uygun fiyat garantisi.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-eymen-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-koyu-800 mb-2">{company.experience} Yıllık Tecrübe</h3>
          <p class="text-koyu-500 text-sm">1999'dan beri reklam ve baskı sektöründe güvenilir hizmet sunuyoruz.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-eymen-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-koyu-800 mb-2">Hızlı Üretim</h3>
          <p class="text-koyu-500 text-sm">Kendi üretim tesisimizde siparişlerinizi hızla hazırlayıp teslim ediyoruz.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-eymen-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-koyu-800 mb-2">Uygun Fiyat</h3>
          <p class="text-koyu-500 text-sm">Aracısız, doğrudan üreticiden rekabetçi fiyatlarla UV baskı hizmeti.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-eymen-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-koyu-800 mb-2">Yüksek Çözünürlük</h3>
          <p class="text-koyu-500 text-sm">1440 DPI çözünürlükte fotoğraf kalitesinde baskı, canlı ve kalıcı renkler.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-eymen-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-koyu-800 mb-2">8 Farklı Malzeme</h3>
          <p class="text-koyu-500 text-sm">Cam, pleksi, ahşap, metal, seramik, kompozit, foreks ve deri yüzeylere baskı.</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 bg-eymen-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-eymen-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h3 class="text-lg font-bold text-koyu-800 mb-2">Pendik Lokasyon</h3>
          <p class="text-koyu-500 text-sm">İstanbul Anadolu Yakası'nda kolay ulaşılabilir üretim tesisi.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="bg-eymen-500 py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4">Projeniz İçin Teklif Alın</h2>
      <p class="text-eymen-100 text-lg mb-8">Malzeme ve boyut bilgilerini gönderin, size en kısa sürede fiyat teklifi sunalım.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/teklif-al" class="inline-flex items-center justify-center gap-2 bg-white text-eymen-600 hover:bg-koyu-50 px-8 py-4 rounded-xl text-lg font-bold transition-all">
          Online Teklif Formu
        </a>
        <a href={`tel:${contact.mobile.replace(/\s/g, '')}`} class="inline-flex items-center justify-center gap-2 border-2 border-white text-white hover:bg-white hover:text-eymen-600 px-8 py-4 rounded-xl text-lg font-bold transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          {contact.mobile}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
