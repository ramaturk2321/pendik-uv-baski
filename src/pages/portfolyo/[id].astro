---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projeler = await getCollection('projeler');
  return projeler.map(p => ({
    params: { id: p.id },
    props: { proje: p },
  }));
}

const { proje } = Astro.props;
const data = proje.data;
const { Content } = await render(proje);
---

<BaseLayout title={data.title} description={data.description}>

  <!-- Breadcrumb -->
  <nav class="bg-koyu-50 border-b border-koyu-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <ol class="flex items-center gap-2 text-sm text-koyu-500">
        <li><a href="/" class="hover:text-eymen-600">Ana Sayfa</a></li>
        <li><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li><a href="/portfolyo" class="hover:text-eymen-600">Portfolyo</a></li>
        <li><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
        <li class="text-koyu-800 font-medium">{data.title}</li>
      </ol>
    </div>
  </nav>

  <section class="py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <img src={data.image} alt={data.title} class="w-full rounded-2xl mb-8 shadow-sm" />
      <div class="flex items-center gap-3 mb-4">
        <span class="text-xs font-semibold text-eymen-600 bg-eymen-50 px-3 py-1 rounded-full">{data.material}</span>
        <span class="text-xs text-koyu-400">{data.date}</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-koyu-800 mb-6">{data.title}</h1>
      <div class="prose prose-lg max-w-none text-koyu-600">
        <Content />
      </div>
    </div>
  </section>

</BaseLayout>
