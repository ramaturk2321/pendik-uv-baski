---
import BaseLayout from '../layouts/BaseLayout.astro';
import { contact, hizmetler } from '../lib/site-data';
---

<BaseLayout title="Online Teklif Al" description="UV baskı teklif formu — Malzeme, boyut ve adet bilgilerinizi gönderin, size hızlıca fiyat teklifi sunalım.">

  <!-- Hero -->
  <section class="bg-koyu-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-extrabold mb-4">Online Teklif Al</h1>
      <p class="text-koyu-300 text-lg max-w-2xl mx-auto">Formu doldurun, en kısa sürede size özel fiyat teklifi gönderelim.</p>
    </div>
  </section>

  <section class="py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <form class="space-y-6 bg-white rounded-2xl border border-koyu-100 shadow-sm p-8">
        <!-- Ad Soyad -->
        <div>
          <label for="name" class="block text-sm font-semibold text-koyu-700 mb-2">Ad Soyad *</label>
          <input type="text" id="name" name="name" required class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" placeholder="Adınız Soyadınız" />
        </div>

        <!-- Telefon + E-posta -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="phone" class="block text-sm font-semibold text-koyu-700 mb-2">Telefon *</label>
            <input type="tel" id="phone" name="phone" required class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" placeholder="05XX XXX XX XX" />
          </div>
          <div>
            <label for="email" class="block text-sm font-semibold text-koyu-700 mb-2">E-posta</label>
            <input type="email" id="email" name="email" class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" placeholder="ornek@email.com" />
          </div>
        </div>

        <!-- Malzeme Seçimi -->
        <div>
          <label for="material" class="block text-sm font-semibold text-koyu-700 mb-2">Baskı Yapılacak Malzeme *</label>
          <select id="material" name="material" required class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors bg-white">
            <option value="">Malzeme seçiniz...</option>
            {hizmetler.map(h => (
              <option value={h.id}>{h.title}</option>
            ))}
            <option value="diger">Diğer</option>
          </select>
        </div>

        <!-- Boyut + Adet -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <label for="width" class="block text-sm font-semibold text-koyu-700 mb-2">En (cm)</label>
            <input type="number" id="width" name="width" class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" placeholder="100" />
          </div>
          <div>
            <label for="height" class="block text-sm font-semibold text-koyu-700 mb-2">Boy (cm)</label>
            <input type="number" id="height" name="height" class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" placeholder="60" />
          </div>
          <div>
            <label for="quantity" class="block text-sm font-semibold text-koyu-700 mb-2">Adet</label>
            <input type="number" id="quantity" name="quantity" min="1" class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors" placeholder="1" />
          </div>
        </div>

        <!-- Açıklama -->
        <div>
          <label for="message" class="block text-sm font-semibold text-koyu-700 mb-2">Proje Detayları</label>
          <textarea id="message" name="message" rows="4" class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors resize-none" placeholder="Projeniz hakkında detay verebilirsiniz..."></textarea>
        </div>

        <!-- Dosya Yükleme -->
        <div>
          <label for="file" class="block text-sm font-semibold text-koyu-700 mb-2">Tasarım Dosyası (Opsiyonel)</label>
          <input type="file" id="file" name="file" accept=".pdf,.jpg,.jpeg,.png,.ai,.psd,.cdr" class="w-full px-4 py-3 border-2 border-koyu-200 rounded-xl focus:border-eymen-500 focus:outline-none transition-colors text-sm text-koyu-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-eymen-50 file:text-eymen-600 file:font-semibold file:text-sm hover:file:bg-eymen-100" />
          <p class="text-xs text-koyu-400 mt-1">PDF, JPG, PNG, AI, PSD, CDR — Maks. 10 MB</p>
        </div>

        <!-- Gönder -->
        <button type="submit" class="w-full bg-eymen-500 hover:bg-eymen-600 text-white py-4 rounded-xl text-lg font-bold transition-all hover:shadow-lg hover:shadow-eymen-500/20">
          Teklif Talebini Gönder
        </button>

        <p class="text-center text-xs text-koyu-400">
          Veya doğrudan arayın: <a href={contact.mobileHref} class="text-eymen-600 font-semibold hover:underline">{contact.mobile}</a>
        </p>
      </form>
    </div>
  </section>

</BaseLayout>
